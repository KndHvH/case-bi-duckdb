	partition d_calendar = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    CALENDAR(
				        MIN(vw_lote[data_recebimento]), 
				        MAX(vw_lote[data_vencimento])
				    ),
				    "year",             YEAR([Date]),
				    "quarter",          QUARTER([Date]),
				    "quarter_name",     "T" & QUARTER([Date]),
				    "month",            MONTH([Date]),
				    "month_name",       FORMAT([Date], "MMMM"),
				    "week_number",      WEEKNUM([Date], 2),         
				    "week_name",        "Semana " & WEEKNUM([Date], 2),
				    "day_of_month",     DAY([Date]),
				    "day_of_week",      WEEKDAY([Date], 2),
				    "day_name",         FORMAT([Date], "DDDD"),
				    "day_name_short",   FORMAT([Date], "DDD"),
				    "full_date",        FORMAT([Date], "DD/MM")
				)
				```

	annotation PBI_Id = bcf9ef6ec8954678a71b4e958bb70c68

